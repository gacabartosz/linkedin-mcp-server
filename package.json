{
  "name": "linkedin-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for LinkedIn — create posts, schedule content, generate AI images, manage comments. The only LinkedIn MCP with write operations.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "linkedin-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const f='dist/index.js',c=require('fs');let s=c.readFileSync(f,'utf8');if(!s.startsWith('#!'))c.writeFileSync(f,'#!/usr/bin/env node\\n'+s)\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "linkedin",
    "social-media",
    "ai",
    "claude",
    "model-context-protocol",
    "scheduling",
    "content-creation",
    "gemini",
    "imagen"
  ],
  "author": "Bartosz Gaca <kontakt@bartoszgaca.pl> (https://bartoszgaca.pl)",
  "repository": {
    "type": "git",
    "url": "https://github.com/gacabartosz/linkedin-mcp-server"
  },
  "homepage": "https://bartoszgaca.pl",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "templates",
    "guidelines",
    "README.md",
    "LICENSE"
  ]
}
